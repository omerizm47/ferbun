{
  "expo": {
    "name": "Fêrbûn — Learn Kurdish",
    "slug": "ferbun",
    "version": "1.5.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E85D00"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ferbun.app",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E85D00"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.ferbun.app",
      "versionCode": 5
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "76993b45-c830-4319-82f3-f56b6082357a"
      }
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#E85D00"
        }
      ]
    ]
  }
}
